    "test:watch": "bun test --watch",
    "generate-icons": "bun run scripts/generate-icons.js",
    "clean": "bun run scripts/clean.js",
    "setup": "bun run scripts/setup.js",
    "check-deps": "bun run scripts/check-deps.js",
    "pre-commit": "bun run scripts/pre-commit.js",
    "analyze": "ANALYZE=true bun run build"
  },
  "dependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "autoprefixer": "10.4.24",
    "clsx": "2.1.1",
    "framer-motion": "12.34.2",
    "fuse.js": "7.1.0",
    "gray-matter": "4.0.3",
    "katex": "0.16.38",
    "lenis": "1.3.17",
